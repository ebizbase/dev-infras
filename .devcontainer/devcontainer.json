{
  "name": "devcontainer",
  "build": {
    "dockerfile": "../images/devcontainer/Dockerfile",
    "context": "..",
    "cacheFrom": [
      "type=registry,ref=ghcr.io/ebizbase/devcontainer:node"
    ]
  },
  "mounts": [
    "source=dev-infra-pnpm,target=/var/lib/pnpm,type=volume",
    "source=dev-infra-dind,target=/var/lib/docker,type=volume",
    "source=dev-infra-trunk,target=/root/.cache/trunk,type=volume"
  ],
  "runArgs": [
    "--name=dev-infra-devcontainer",
    "--privileged"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/dev-infra,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/dev-infra",
  "overrideCommand": false,
  "postStartCommand": "pnpm install",
  "customizations": {
    "vscode": {
      "settings": {
        "files.associations": {
          // accept json with comments
          "*.json": "jsonc"
        },
        "files.exclude": {
          "**/.git": true,
          "**/.svn": true,
          "**/.hg": true,
          "**/.DS_Store": true,
          "**/Thumbs.db": true,
          "trunk-*": true
        }
      },
      "extensions": [
        "editorconfig.editorconfig",
        "esbenp.prettier-vscode",
        "shd101wyy.markdown-preview-enhanced",
        "firsttris.vscode-jest-runner",
        "steoates.autoimport",
        "bradlc.vscode-tailwindcss",
        "github.vscode-github-actions",
        "redhat.vscode-yaml"
      ]
    }
  }
}
